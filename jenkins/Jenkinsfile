pipeline {

    agent any

    environment {

        ANSIBLE_HOST_KEY_CHECKING = "False"

        ANSIBLE_CONFIG = "${WORKSPACE}/ansible.cfg"

        PACKER_LOG = "1"
    }

    stages {

        stage('Checkout Code') {

            steps {

                git branch: 'main',
                url: 'https://github.com/Sameer-Sarrainodu/ecommerce-ansible.git'
            }
        }

        stage('Verify Ansible') {

            steps {

                sh 'ansible --version'
            }
        }

        // stage('Deploy Infrastructure Components') {

        //     steps {

        //         sh '''
        //             chmod +x jenkins/deploy.sh
        //             ./jenkins/deploy.sh
        //         '''
        //     }
        // }

        stage('Cleanup Old Installations') {

            steps {

                sh '''
                    ansible-playbook \
                    -i inventories/dev/hosts.ini \
                    playbooks/cleanup.yml
                '''
            }
        }
    }

    post {

        success {

            echo '✅ DB deployment and Catalogue image build completed successfully!'
        }

        failure {

            echo '❌ Pipeline failed!'
        }
    }
}