worker_processes auto;

events {
    worker_connections 1024;
}

http {

    resolver 168.63.129.16 valid=10s;

    include       /etc/nginx/mime.types;

    default_type  application/octet-stream;

    sendfile on;

    include /etc/nginx/conf.d/*.conf;

    server {

        listen 80;

        server_name _;

        root /usr/share/nginx/html;

        index index.html;

        location / {

            try_files $uri /index.html;
        }

        location /images/ {

            expires 5s;

            root /usr/share/nginx/html;

            try_files $uri /images/placeholder.jpg;
        }

        location /api/catalogue/ {

            rewrite ^/api/catalogue/(.*)$ /$1 break;

            proxy_pass http://catalogue.backend.sharkdev.shop;

            proxy_set_header Host catalogue.backend.sharkdev.shop;
        }

        location /api/user/ {

            rewrite ^/api/user/(.*)$ /$1 break;

            proxy_pass http://user.backend.sharkdev.shop;

            proxy_set_header Host user.backend.sharkdev.shop;
        }

        location /api/cart/ {

            rewrite ^/api/cart/(.*)$ /$1 break;

            proxy_pass http://cart.backend.sharkdev.shop;

            proxy_set_header Host cart.backend.sharkdev.shop;
        }

        location /api/shipping/ {

            rewrite ^/api/shipping/(.*)$ /$1 break;

            proxy_pass http://shipping.backend.sharkdev.shop;

            proxy_set_header Host shipping.backend.sharkdev.shop;
        }

        location /api/payment/ {

            rewrite ^/api/payment/(.*)$ /$1 break;

            proxy_pass http://payment.backend.sharkdev.shop;

            proxy_set_header Host payment.backend.sharkdev.shop;
        }

        location /health {

            stub_status on;

            access_log off;
        }
    }
}