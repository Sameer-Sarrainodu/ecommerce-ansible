[Unit]
Description=Payment Service

[Service]
User={{ app_user }}
WorkingDirectory={{ app_home }}
Environment=CART_HOST=cart.backend.sharkdev.shop
Environment=CART_PORT=80
Environment=USER_HOST=user.backend.sharkdev.shop
Environment=USER_PORT=80
Environment=AMQP_HOST=rabbitmq.roboshop.internal
Environment=AMQP_USER=roboshop
Environment=AMQP_PASS=roboshop@123
ExecStart=/usr/bin/python3 {{ app_home }}/payment.py
SyslogIdentifier=payment

[Install]
WantedBy=multi-user.target